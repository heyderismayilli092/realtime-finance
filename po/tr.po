msgid "Realtime Finance"
msgstr "Gerçek Zamanlı Finans"

msgid "A simple application that displays currency and gold exchange rate changes on the Linux desktop screen"
msgstr "Linux masaüstü ekranında döviz ve altın kur değişikliklerini gösteren basit bir uygulama"

msgid "Real-time data:"
msgstr "Gerçek zamanlı veri:"

msgid "Data is being retrieved..."
msgstr "Veriler alınıyor..."

msgid "Could not connect to the API service.\nPlease check your internet connection"
msgstr "API hizmetine bağlanılamadı.\nLütfen internet bağlantınızı kontrol ediniz"

msgid "The connection timed out.\nPlease close and reopen the app to try again"
msgstr "Bağlantı zaman aşımına uğradı.\nLütfen uygulamayı kapatıp tekrar açarak yeniden deneyin"

msgid "Dollar"
msgstr "Dolar"

msgid "Euro"
msgstr "Euro"

msgid "Quarter gold"
msgstr "Çeyrek altın"

msgid "Gram gold"
msgstr "Gram altın"

msgid "Exit"
msgstr "Çıkış"

msgid "Close"
msgstr "Kapat"
